@using DashboardData.Models
@using DashboardData.Services
@page "/dashboard"
@rendermode InteractiveServer
@attribute [StreamRendering]
@inject ISensorService SensorService
@inject NavigationManager NavManager



<button class="btn btn-secondary mb-3" @onclick="LoadAll">Toutes les sondes</button>
<button class="btn btn-danger mb-3" @onclick="LoadCritical">Alertes (> 30.0)</button>
<a href="/edit-sensor" class="btn btn-success mb-3">+ Nouveau Capteur</a>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Total Sondes</h5>
                <h2>@TotalSensors</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Moyenne Globale</h5>
                <h2>@Average.ToString("F1") °C</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h5 class="card-title">Valeur Maximale</h5>
                <h2>@MaxValue.ToString("F1") °C</h2>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <p>Chargement en cours...</p>
}
else if (Sensors == null)
{
    <p>Erreur lors du chargement des données.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Sensor</th>
                <th>Location</th>
                <th>Current Value</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sensor in Sensors)
            {
                <tr>
                    <td>@sensor.Name</td>
                    <td>@(sensor.Location?.Name ?? "Undefined")</td>
                    <td>@sensor.Value</td>
                    <td>
                        
                        <a href="/edit-sensor/@sensor.Id" class="btn btn-sm btn-outline-primary">Éditer</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSensor(sensor.Id)">Supprimer</button>
                        
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<SensorData>? Sensors;
    private bool isLoading = true;

    private int TotalSensors;
    private double Average;
    private double MaxValue ;

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadAll()
    {
        try
        {
            Sensors = await SensorService.GetSensorsAsync();
            TotalSensors = await SensorService.GetTotalCountAsync();
            Average = await SensorService.GetAverageValueAsync();
            MaxValue = await SensorService.GetMaxValueAsync();
        }
        catch (Exception ex)
        {
            Sensors = null;
            Console.WriteLine($"Erreur lors du chargement: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task LoadCritical()
    {
        try
        {
            Sensors = await SensorService.GetCriticalSensorsAsync(30.0);
            // Rafraîchir les KPIs même pour les capteurs critiques
            TotalSensors = await SensorService.GetTotalCountAsync();
            Average = await SensorService.GetAverageValueAsync();
            MaxValue = await SensorService.GetMaxValueAsync();
        }
        catch (Exception ex)
        {
            Sensors = null;
            Console.WriteLine($"Erreur lors du chargement des capteurs critiques: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task DeleteSensor(int id)
    {
        try
        {
            await SensorService.DeleteSensorAsync(id);
            await LoadAll();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
        }
    }
}